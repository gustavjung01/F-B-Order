  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-admin-encoding.mjs && node scripts/write-app-version.mjs && node --test scripts/write-app-version.test.mjs",
    "icons:gen": "node scripts/generate-pwa-icons.cjs",
    "catalog:normalize": "node scripts/import-hung-phat-catalog.mjs",
