{
  "name": "@fb-order/backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "echo \"lint backend later\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:verify:order-contract": "node scripts/verify-core-order-contract.mjs",
    "db:seed:test": "node scripts/run-sql.mjs db/seeds/001_seed_test.sql",
    "catalog:audit": "node scripts/audit-catalog-source.mjs",
    "catalog:import": "node scripts/import-hung-phat-catalog.mjs"
  },
  "dependencies": {
    "@clerk/express": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
