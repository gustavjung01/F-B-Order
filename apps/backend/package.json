{
  "name": "@fb-order/backend",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/ai-worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/ai-worker.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:auth-pricing": "tsx scripts/test-auth-pricing.ts",
    "test:catalog-contract": "tsx scripts/test-catalog-contract.ts",
    "test:catalog-v2": "tsx scripts/test-catalog-v2.ts",
    "test:admin-products": "tsx scripts/test-admin-products-contract.ts",
    "test:order-engine": "tsx scripts/test-order-engine.ts",
    "test:recipe-scale": "tsx scripts/test-recipe-scale.ts",
    "test:recipe-workflow": "tsx scripts/test-admin-recipe-workflow.ts",
    "test:recipe-version-analysis": "tsx scripts/test-recipe-version-analysis.ts",
    "test:kitchen-capacity": "tsx scripts/test-kitchen-capacity.ts",
    "test:ai-draft-workflow": "tsx scripts/test-ai-draft-workflow.ts",
    "test:recipe-rd": "tsx scripts/test-recipe-rd.ts",
    "test:recipe-rd-trial-audit": "tsx scripts/test-recipe-rd-trial-audit.ts",
    "test:production-planning": "tsx scripts/test-production-planning.ts",
    "test:ai-provider": "tsx --test test/google-agent.provider.test.ts",
    "recipe-media:cleanup": "tsx scripts/cleanup-recipe-media.ts",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:migrate:baseline": "node scripts/run-migrations.mjs --baseline-existing",
    "db:test:migrations": "node scripts/test-migrations.mjs",
    "db:audit:schema": "node scripts/audit-db-schema.mjs",
    "db:verify:order-contract": "node scripts/verify-core-order-contract.mjs",
    "db:seed:test": "node scripts/run-sql.mjs db/seeds/001_seed_test.sql",
    "catalog:audit": "node scripts/audit-catalog-source.mjs",
    "catalog:import": "node scripts/import-hung-phat-catalog.mjs",
    "catalog:v2:dry-run": "node scripts/import-catalog-v2.mjs",
    "catalog:v2:apply": "node scripts/import-catalog-v2.mjs --apply",
    "recipe:images:upload": "node scripts/upload-recipe-images-r2.mjs",
    "recipe:content:import": "node scripts/import-recipes-v1.mjs",
    "recipe:content:validate": "node scripts/validate-recipes-v1.mjs",
    "test:rbac": "tsx --test test/auth.permissions.test.ts"
  },
  "dependencies": {
    "@clerk/express": "2.1.28",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "google-auth-library": "9.15.1",
    "helmet": "8.2.0",
    "pg": "8.21.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "tsx": "4.19.2",
    "typescript": "6.0.3"
  }
}
