{
  "name": "f-b-order",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "npm run build:frontend",
    "build:all": "pnpm -r build",
    "build:frontend": "npm --workspace @fb-order/frontend run build",
    "build:backend": "npm --workspace @fb-order/backend run build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
