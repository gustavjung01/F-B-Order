{
  "name": "f-b-order",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "20.x || 22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm run build:frontend",
    "build:all": "pnpm -r build",
    "build:frontend": "pnpm --filter @fb-order/frontend build",
    "build:backend": "pnpm --filter @fb-order/backend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:catalog-parent": "pnpm catalog:map:v2 && pnpm catalog:preview:parent:v2 && pnpm frontend:audit:copy && pnpm typecheck && pnpm run build:frontend",
    "test:auth-pricing": "pnpm --filter @fb-order/backend test:auth-pricing",
    "db:migrate": "pnpm --filter @fb-order/backend db:migrate",
    "db:migrate:baseline": "pnpm --filter @fb-order/backend db:migrate:baseline",
    "db:test:migrations": "pnpm --filter @fb-order/backend db:test:migrations",
    "db:verify:order-contract": "pnpm --filter @fb-order/backend db:verify:order-contract",
    "db:seed:test": "pnpm --filter @fb-order/backend db:seed:test",
    "catalog:audit": "pnpm --filter @fb-order/backend catalog:audit",
    "catalog:import": "pnpm --filter @fb-order/backend catalog:import",
    "catalog:map:v2": "node scripts/catalog/hung-phat-v2/build-parent-map.mjs",
    "catalog:manifest:v2": "pnpm catalog:map:v2 && node scripts/catalog/hung-phat-v2/prepare-phase4-r2-v2.mjs",
    "catalog:audit:content:v2": "node scripts/catalog/hung-phat-v2/build-content-audit.mjs && node scripts/catalog/hung-phat-v2/build-tea-group-audit.mjs",
    "catalog:audit:tea-groups:v2": "node scripts/catalog/hung-phat-v2/build-tea-group-audit.mjs",
    "catalog:db:audit:heroku:v2": "pnpm --filter @fb-order/backend catalog:v2:dry-run",
    "test:catalog-api:v2": "pnpm --filter @fb-order/backend test:catalog-v2",
    "frontend:audit:copy": "node scripts/frontend/audit-production-copy.mjs",
    "catalog:preview:v2": "node scripts/catalog/hung-phat-v2/build-phase3-preview.mjs",
    "catalog:preview:parent:v2": "node scripts/catalog/hung-phat-v2/build-parent-map.mjs && node scripts/catalog/hung-phat-v2/build-parent-preview-v2.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
