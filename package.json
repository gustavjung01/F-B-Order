{
  "name": "f-b-order",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "20.x || 22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm run build:frontend",
    "build:all": "pnpm -r build",
    "build:frontend": "pnpm --filter @fb-order/frontend build",
    "build:backend": "pnpm --filter @fb-order/backend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:auth-pricing": "pnpm --filter @fb-order/backend test:auth-pricing",
    "db:migrate": "pnpm --filter @fb-order/backend db:migrate",
    "db:migrate:baseline": "pnpm --filter @fb-order/backend db:migrate:baseline",
    "db:test:migrations": "pnpm --filter @fb-order/backend db:test:migrations",
    "db:verify:order-contract": "pnpm --filter @fb-order/backend db:verify:order-contract",
    "db:seed:test": "pnpm --filter @fb-order/backend db:seed:test",
    "catalog:audit": "pnpm --filter @fb-order/backend catalog:audit",
    "catalog:import": "pnpm --filter @fb-order/backend catalog:import"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
